# ── API KEY de OpenAI ── (NUNCA committear el .env real)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo a usar (gpt-4o-mini recomendado por costo/calidad)
OPENAI_MODEL=gpt-4o-mini

# Puerto del backend Express embebido
BACKEND_PORT=4317

# Path de la base de datos SQLite (relativo al proyecto)
DB_PATH=./backend/db/op-onboarding.sqlite
