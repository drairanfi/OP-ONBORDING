{
  "name": "op-onboarding",
  "version": "0.1.0",
  "private": true,
  "description": "Onboarding desktop app for Omnicom Production Latam",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "node backend/server.js",
    "dev": "concurrently -k -n FE,EL -c blue,magenta \"npm:dev:frontend\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && electron-builder",
    "start": "cross-env NODE_ENV=production electron ."
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "openai": "^4.67.3"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.oplatam.onboarding",
    "productName": "OP Latam Onboarding",
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
